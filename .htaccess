# SMFM Security Configuration
# Защита конфигурации, логов и временных файлов

# Включаем FollowSymLinks для корректной работы mod_rewrite
Options +FollowSymLinks -Indexes

# Защита конфигурационных файлов
<FilesMatch "^(config\.php|generate_hash\.php)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Защита логов
<FilesMatch "\.(log|txt)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Защита скрытых файлов (.htaccess, .git, и т.д.)
<FilesMatch "^\.">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Блокировка выполнения PHP в директории uploads
<Directory "uploads">
    php_flag engine off
    RemoveHandler .php .phtml .php3 .php4 .php5 .phps
    RemoveType .php .phtml .php3 .php4 .php5 .phps
    <FilesMatch "\.php$">
        Order Allow,Deny
        Deny from all
    </FilesMatch>
</Directory>

# Блокировка доступа к директории chunks
<Directory "chunks">
    Order Allow,Deny
    Deny from all
</Directory>

# Защита от hotlinking (опционально, раскомментируйте при необходимости)
# RewriteEngine on
# RewriteCond %{HTTP_REFERER} !^$
# RewriteCond %{HTTP_REFERER} !^http(s)?://(www\.)?yourdomain.com [NC]
# RewriteRule \.(jpg|jpeg|png|gif|mp4|mp3|zip|pdf)$ - [NC,F,L]

# Установка правильных MIME-типов
AddType application/octet-stream .apk
AddType video/mp4 .mp4
AddType audio/mpeg .mp3

# Увеличение лимитов для загрузки (если сервер позволяет)
php_value upload_max_filesize 2048M
php_value post_max_size 2048M
php_value max_execution_time 3600
php_value max_input_time 3600

# Отключение отображения ошибок PHP (безопасность)
php_flag display_errors off
php_flag display_startup_errors off

# Защита от XSS
<IfModule mod_headers.c>
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Сжатие для ускорения загрузки
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Кеширование статических ресурсов
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
